# --- Core ---
APP_TOKEN=change-me-long-random-string
DATABASE_URL=postgresql+asyncpg://subjects:subjects@postgres:5432/subjects
# procrastinate + LISTEN/NOTIFY use a plain psycopg conninfo
DATABASE_DSN=postgresql://subjects:subjects@postgres:5432/subjects
POSTGRES_USER=subjects
POSTGRES_PASSWORD=subjects
POSTGRES_DB=subjects

# --- AI provider ---
AI_PROVIDER=ollama                      # ollama | openai | nim
OLLAMA_BASE_URL=http://host.docker.internal:11434
VISION_MODEL=qwen2.5vl:7b               # fallback slot: minicpm-v
TEXT_MODEL=qwen2.5vl:7b                 # reuse VLM or a small qwen3
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# NVIDIA NIM (self-hosted microservice or build.nvidia.com catalog)
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1   # or http://host.docker.internal:8000/v1 for self-hosted
NIM_VISION_MODEL=meta/llama-3.2-11b-vision-instruct   # 90b hangs on NVIDIA's hosted side; 11b works
NIM_TEXT_MODEL=meta/llama-3.1-70b-instruct
NIM_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# --- External APIs ---
GITHUB_TOKEN=
TMDB_API_KEY=

# --- Pipeline ---
CONFIDENCE_AUTO=0.8
DEDUP_THRESHOLD=0.90

# --- Search (Phase 4) ---
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=change-me-meili-key

# --- Storage ---
DATA_DIR=/data
# Public base URL the web app / phone will use to reach the API (for media links)
PUBLIC_BASE_URL=http://localhost:8000
